# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=979712
POSTGRES_DB=tms
POSTGRES_PORT=5432

# Backend Configuration
BACKEND_PORT=8080
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_JWT_KEY_AT_LEAST_32_CHARACTERS_LONG
SPRING_PROFILES_ACTIVE=prod

# JVM Options (adjust based on VPS resources)
JAVA_OPTS=-Xmx1024m -Xms512m -XX:+UseG1GC

# Frontend Configuration
FRONTEND_PORT=80

# CORS Configuration (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://yourdomain.com

# Production Notes:
# 1. Change all passwords and secrets
# 2. Use HTTPS in production
# 3. Consider using a reverse proxy (nginx/traefik) for SSL termination
# 4. Set up proper firewall rules
# 5. Configure backup strategy for database